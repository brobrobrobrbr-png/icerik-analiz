PORT=3000

# ─── YouTube Data API v3 (gerçek veri için doldurun) ─────────────────────
# 1) https://console.cloud.google.com/ → Proje oluştur
# 2) "YouTube Data API v3" etkinleştir
# 3) Kimlik bilgileri → API anahtarı oluştur
# 4) Anahtarı .env dosyasına yapıştır (.env.example DEĞİL!)
YOUTUBE_API_KEY=AIzaSyCtUaLWY00W8TS_jl3lC-kevnbIqmNXs3Y

# true  → Demo veri (API anahtarı gerekmez)
# false → YouTube API kullanılır (YOUTUBE_API_KEY gerekli)
USE_MOCK_DATA=false

# ─── Anthropic Claude API (AI trend analizi için) ────────────────────────
# 1) https://console.anthropic.com/ → API Keys → Create Key
# 2) Anahtarı .env dosyasına yapıştırın (.env.example DEĞİL!)
# Tanımlı değilse AI analiz bölümü otomatik olarak gizlenir, arama
# özelliği bundan etkilenmez.
ANTHROPIC_API_KEY=
